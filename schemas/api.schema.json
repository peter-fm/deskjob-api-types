{
  "$defs": {
    "AcceptedTurn": {
      "properties": {
        "seq": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "turn_id": {
          "type": "string"
        }
      },
      "required": [
        "turn_id",
        "seq"
      ],
      "type": "object"
    },
    "ApiStreamFrame": {
      "oneOf": [
        {
          "properties": {
            "channel_id": {
              "examples": [
                "public:default",
                "dm:agent:pete"
              ],
              "pattern": "^(public:default|dm:agent:[A-Za-z0-9._-]+)$",
              "type": "string"
            },
            "event": {
              "$ref": "#/$defs/EngineEvent"
            },
            "project": {
              "type": "string"
            },
            "seq": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "turn_id": {
              "type": "string"
            },
            "type": {
              "const": "engine_event",
              "type": "string"
            }
          },
          "required": [
            "type",
            "seq",
            "project",
            "channel_id",
            "turn_id",
            "event"
          ],
          "type": "object"
        },
        {
          "properties": {
            "channel_id": {
              "examples": [
                "public:default",
                "dm:agent:pete"
              ],
              "pattern": "^(public:default|dm:agent:[A-Za-z0-9._-]+)$",
              "type": "string"
            },
            "event": {
              "$ref": "#/$defs/TranscriptEntry"
            },
            "project": {
              "type": "string"
            },
            "seq": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "turn_id": {
              "type": "string"
            },
            "type": {
              "const": "transcript_entry",
              "type": "string"
            }
          },
          "required": [
            "type",
            "seq",
            "project",
            "channel_id",
            "turn_id",
            "event"
          ],
          "type": "object"
        }
      ]
    },
    "ChannelEntry": {
      "properties": {
        "display_name": {
          "type": "string"
        },
        "id": {
          "examples": [
            "public:default",
            "dm:agent:pete"
          ],
          "pattern": "^(public:default|dm:agent:[A-Za-z0-9._-]+)$",
          "type": "string"
        },
        "private": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "display_name",
        "private"
      ],
      "type": "object"
    },
    "ChannelsPayload": {
      "properties": {
        "channels": {
          "items": {
            "$ref": "#/$defs/ChannelEntry"
          },
          "type": "array"
        },
        "project": {
          "type": "string"
        }
      },
      "required": [
        "project",
        "channels"
      ],
      "type": "object"
    },
    "DreamEntry": {
      "properties": {
        "inputs": true,
        "outputs": true,
        "project": {
          "$ref": "#/$defs/ProjectRef"
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "tier": {
          "type": "string"
        },
        "timestamp": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "project",
        "tier",
        "timestamp",
        "inputs",
        "outputs"
      ],
      "type": "object"
    },
    "DreamsPayload": {
      "properties": {
        "dreams": {
          "items": {
            "$ref": "#/$defs/DreamEntry"
          },
          "type": "array"
        },
        "remote_errors": {
          "items": true,
          "type": "array"
        }
      },
      "required": [
        "dreams",
        "remote_errors"
      ],
      "type": "object"
    },
    "DreamsQuery": {
      "properties": {
        "project": {
          "type": [
            "string",
            "null"
          ]
        },
        "since": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "tier": {
          "type": [
            "string",
            "null"
          ]
        },
        "verbose": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "EngineEvent": {
      "oneOf": [
        {
          "properties": {
            "content": {
              "type": "string"
            },
            "type": {
              "const": "text_delta",
              "type": "string"
            }
          },
          "required": [
            "type",
            "content"
          ],
          "type": "object"
        },
        {
          "properties": {
            "arguments": true,
            "call_id": {
              "type": "string"
            },
            "tool_name": {
              "type": "string"
            },
            "type": {
              "const": "tool_call",
              "type": "string"
            }
          },
          "required": [
            "type",
            "tool_name",
            "arguments",
            "call_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "call_id": {
              "type": "string"
            },
            "result": {
              "type": "string"
            },
            "type": {
              "const": "tool_result",
              "type": "string"
            }
          },
          "required": [
            "type",
            "call_id",
            "result"
          ],
          "type": "object"
        },
        {
          "properties": {
            "context_usage": {
              "format": "float",
              "type": "number"
            },
            "transcript": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "type": {
              "const": "compaction_pending",
              "type": "string"
            }
          },
          "required": [
            "type",
            "transcript",
            "context_usage"
          ],
          "type": "object"
        },
        {
          "properties": {
            "session_id": {
              "type": "string"
            },
            "type": {
              "const": "complete",
              "type": "string"
            }
          },
          "required": [
            "type",
            "session_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "session_id": {
              "type": "string"
            },
            "type": {
              "const": "interrupted",
              "type": "string"
            }
          },
          "required": [
            "type",
            "session_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "message": {
              "type": "string"
            },
            "type": {
              "const": "error",
              "type": "string"
            }
          },
          "required": [
            "type",
            "message"
          ],
          "type": "object"
        }
      ]
    },
    "EngineSelection": {
      "enum": [
        "codex",
        "opus",
        "claude"
      ],
      "type": "string"
    },
    "GetChannelsRoute": {
      "properties": {
        "path": {
          "$ref": "#/$defs/ProjectPath"
        },
        "response": {
          "$ref": "#/$defs/ChannelsPayload"
        }
      },
      "required": [
        "path",
        "response"
      ],
      "type": "object"
    },
    "GetDreamsRoute": {
      "properties": {
        "query": {
          "$ref": "#/$defs/DreamsQuery"
        },
        "response": {
          "$ref": "#/$defs/DreamsPayload"
        }
      },
      "required": [
        "query",
        "response"
      ],
      "type": "object"
    },
    "GetMemoryRoute": {
      "properties": {
        "query": {
          "$ref": "#/$defs/MemoryQuery"
        },
        "response": {
          "$ref": "#/$defs/MemoryPayload"
        }
      },
      "required": [
        "query",
        "response"
      ],
      "type": "object"
    },
    "GetMessagesRoute": {
      "properties": {
        "path": {
          "$ref": "#/$defs/ProjectChannelPath"
        },
        "query": {
          "$ref": "#/$defs/MessagesQuery"
        },
        "response": {
          "$ref": "#/$defs/MessagesPayload"
        }
      },
      "required": [
        "path",
        "query",
        "response"
      ],
      "type": "object"
    },
    "GetProjectsRoute": {
      "properties": {
        "response": {
          "$ref": "#/$defs/ProjectsPayload"
        }
      },
      "required": [
        "response"
      ],
      "type": "object"
    },
    "GetStreamRoute": {
      "properties": {
        "path": {
          "$ref": "#/$defs/ProjectChannelPath"
        },
        "query": {
          "$ref": "#/$defs/StreamQuery"
        },
        "response_frame": {
          "$ref": "#/$defs/ApiStreamFrame"
        }
      },
      "required": [
        "path",
        "query",
        "response_frame"
      ],
      "type": "object"
    },
    "HostNode": {
      "properties": {
        "address": {
          "type": [
            "string",
            "null"
          ]
        },
        "api_bridge": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "online": {
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "online"
      ],
      "type": "object"
    },
    "KillPayload": {
      "properties": {
        "killed": {
          "type": "boolean"
        }
      },
      "required": [
        "killed"
      ],
      "type": "object"
    },
    "MemoryEntry": {
      "properties": {
        "age_days": {
          "format": "int64",
          "type": "integer"
        },
        "id": {
          "type": "string"
        },
        "item": {
          "$ref": "#/$defs/MemoryItemRecord"
        },
        "project": {
          "$ref": "#/$defs/ProjectRef"
        },
        "tier": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "tier",
        "project",
        "age_days",
        "item"
      ],
      "type": "object"
    },
    "MemoryItemKind": {
      "enum": [
        "decision",
        "invariant",
        "bug",
        "task",
        "workflow",
        "preference",
        "open_question",
        "note"
      ],
      "type": "string"
    },
    "MemoryItemRecord": {
      "properties": {
        "cluster_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "created_at": {
          "format": "int64",
          "type": "integer"
        },
        "id": {
          "type": "string"
        },
        "importance": {
          "format": "int64",
          "type": "integer"
        },
        "kind": {
          "$ref": "#/$defs/MemoryItemKind"
        },
        "sources": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "state": {
          "$ref": "#/$defs/MemoryItemState"
        },
        "superseded_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "text": {
          "type": "string"
        },
        "updated_at": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "kind",
        "text",
        "state",
        "importance",
        "sources",
        "created_at",
        "updated_at"
      ],
      "type": "object"
    },
    "MemoryItemState": {
      "enum": [
        "active",
        "resolved",
        "stale",
        "superseded"
      ],
      "type": "string"
    },
    "MemoryPayload": {
      "properties": {
        "items": {
          "items": {
            "$ref": "#/$defs/MemoryEntry"
          },
          "type": "array"
        },
        "remote_errors": {
          "items": true,
          "type": "array"
        },
        "standing_instruction_header": {
          "type": "string"
        }
      },
      "required": [
        "standing_instruction_header",
        "items",
        "remote_errors"
      ],
      "type": "object"
    },
    "MemoryQuery": {
      "properties": {
        "project": {
          "type": [
            "string",
            "null"
          ]
        },
        "since": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "tier": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "MessagesPayload": {
      "properties": {
        "channel_id": {
          "examples": [
            "public:default",
            "dm:agent:pete"
          ],
          "pattern": "^(public:default|dm:agent:[A-Za-z0-9._-]+)$",
          "type": "string"
        },
        "frames": {
          "items": {
            "$ref": "#/$defs/ApiStreamFrame"
          },
          "type": "array"
        },
        "project": {
          "type": "string"
        }
      },
      "required": [
        "project",
        "channel_id",
        "frames"
      ],
      "type": "object"
    },
    "MessagesQuery": {
      "properties": {
        "limit": {
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "since": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "PostKillRoute": {
      "properties": {
        "path": {
          "$ref": "#/$defs/ProjectPath"
        },
        "response": {
          "$ref": "#/$defs/KillPayload"
        }
      },
      "required": [
        "path",
        "response"
      ],
      "type": "object"
    },
    "PostMessageBody": {
      "properties": {
        "channel_id": {
          "examples": [
            "public:default",
            "dm:agent:pete"
          ],
          "pattern": "^(public:default|dm:agent:[A-Za-z0-9._-]+)$",
          "type": "string"
        },
        "engine": {
          "anyOf": [
            {
              "$ref": "#/$defs/EngineSelection"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "message": {
          "type": "string"
        },
        "permission_mode": {
          "type": [
            "string",
            "null"
          ]
        },
        "project": {
          "type": "string"
        }
      },
      "required": [
        "project",
        "channel_id",
        "message"
      ],
      "type": "object"
    },
    "PostMessageRoute": {
      "properties": {
        "request": {
          "$ref": "#/$defs/PostMessageBody"
        },
        "response": {
          "$ref": "#/$defs/AcceptedTurn"
        }
      },
      "required": [
        "request",
        "response"
      ],
      "type": "object"
    },
    "ProjectChannelPath": {
      "properties": {
        "project_channel": {
          "type": "string"
        }
      },
      "required": [
        "project_channel"
      ],
      "type": "object"
    },
    "ProjectEntry": {
      "properties": {
        "display_name": {
          "type": "string"
        },
        "host_node": {
          "$ref": "#/$defs/HostNode"
        },
        "id": {
          "type": "string"
        },
        "is_external": {
          "type": "boolean"
        },
        "owner": {
          "type": "string"
        },
        "qualified_name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "qualified_name",
        "display_name",
        "owner",
        "status",
        "host_node",
        "is_external"
      ],
      "type": "object"
    },
    "ProjectPath": {
      "properties": {
        "project": {
          "type": "string"
        }
      },
      "required": [
        "project"
      ],
      "type": "object"
    },
    "ProjectRef": {
      "properties": {
        "host_node": {
          "$ref": "#/$defs/HostNode"
        },
        "qualified_name": {
          "type": "string"
        }
      },
      "required": [
        "qualified_name",
        "host_node"
      ],
      "type": "object"
    },
    "ProjectsPayload": {
      "properties": {
        "projects": {
          "items": {
            "$ref": "#/$defs/ProjectEntry"
          },
          "type": "array"
        },
        "remote_errors": {
          "items": true,
          "type": "array"
        }
      },
      "required": [
        "projects",
        "remote_errors"
      ],
      "type": "object"
    },
    "StreamQuery": {
      "properties": {
        "last_seq": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "TranscriptEntry": {
      "oneOf": [
        {
          "properties": {
            "content": {
              "type": "string"
            },
            "originator_user_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "const": "user_message",
              "type": "string"
            }
          },
          "required": [
            "type",
            "content"
          ],
          "type": "object"
        },
        {
          "properties": {
            "content": {
              "type": "string"
            },
            "type": {
              "const": "text_delta",
              "type": "string"
            }
          },
          "required": [
            "type",
            "content"
          ],
          "type": "object"
        },
        {
          "properties": {
            "arguments": true,
            "call_id": {
              "type": "string"
            },
            "tool_name": {
              "type": "string"
            },
            "type": {
              "const": "tool_call",
              "type": "string"
            }
          },
          "required": [
            "type",
            "tool_name",
            "arguments",
            "call_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "call_id": {
              "type": "string"
            },
            "result": {
              "type": "string"
            },
            "type": {
              "const": "tool_result",
              "type": "string"
            }
          },
          "required": [
            "type",
            "call_id",
            "result"
          ],
          "type": "object"
        },
        {
          "properties": {
            "context_usage": {
              "format": "float",
              "type": "number"
            },
            "transcript": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "type": {
              "const": "compaction_pending",
              "type": "string"
            }
          },
          "required": [
            "type",
            "transcript",
            "context_usage"
          ],
          "type": "object"
        },
        {
          "properties": {
            "session_id": {
              "type": "string"
            },
            "type": {
              "const": "complete",
              "type": "string"
            }
          },
          "required": [
            "type",
            "session_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "session_id": {
              "type": "string"
            },
            "type": {
              "const": "interrupted",
              "type": "string"
            }
          },
          "required": [
            "type",
            "session_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "message": {
              "type": "string"
            },
            "type": {
              "const": "error",
              "type": "string"
            }
          },
          "required": [
            "type",
            "message"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "get_channels": {
      "$ref": "#/$defs/GetChannelsRoute"
    },
    "get_dreams": {
      "$ref": "#/$defs/GetDreamsRoute"
    },
    "get_memory": {
      "$ref": "#/$defs/GetMemoryRoute"
    },
    "get_messages": {
      "$ref": "#/$defs/GetMessagesRoute"
    },
    "get_projects": {
      "$ref": "#/$defs/GetProjectsRoute"
    },
    "get_stream": {
      "$ref": "#/$defs/GetStreamRoute"
    },
    "post_kill": {
      "$ref": "#/$defs/PostKillRoute"
    },
    "post_message": {
      "$ref": "#/$defs/PostMessageRoute"
    }
  },
  "required": [
    "get_projects",
    "get_channels",
    "post_message",
    "get_messages",
    "get_stream",
    "post_kill",
    "get_memory",
    "get_dreams"
  ],
  "title": "ApiTypes",
  "type": "object"
}
