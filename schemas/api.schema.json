        {
          "properties": {
            "channel_id": {
              "examples": [
                "public:default",
                "dm:agent:pete"
              ],
              "pattern": "^(public:default|dm:agent:[A-Za-z0-9._-]+)$",
              "type": "string"
            },
            "event": {
              "$ref": "#/$defs/EngineEvent"
            },
            "project": {
              "type": "string"
            },
            "seq": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "turn_id": {
              "type": "string"
            },
            "type": {
              "const": "engine_event",
              "type": "string"
            }
          },
          "required": [
            "type",
            "seq",
            "project",
            "channel_id",
            "turn_id",
            "event"
          ],
          "type": "object"
        },
        {
          "properties": {
            "channel_id": {
              "examples": [
                "public:default",
                "dm:agent:pete"
              ],
              "pattern": "^(public:default|dm:agent:[A-Za-z0-9._-]+)$",
              "type": "string"
            },
            "event": {
              "$ref": "#/$defs/TranscriptEntry"
            },
            "project": {
              "type": "string"
            },
            "seq": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "turn_id": {
              "type": "string"
            },
            "type": {
              "const": "transcript_entry",
              "type": "string"
            }
          },
          "required": [
            "type",
            "seq",
            "project",
            "channel_id",
            "turn_id",
            "event"
          ],
          "type": "object"
        }
      ]
    },
    "ApiUser": {
