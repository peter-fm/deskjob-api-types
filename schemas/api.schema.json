    "EngineEvent": {
      "oneOf": [
        {
          "properties": {
            "content": {
              "type": "string"
            },
            "type": {
              "const": "text_delta",
              "type": "string"
            }
          },
          "required": [
            "type",
            "content"
          ],
          "type": "object"
        },
        {
          "properties": {
            "arguments": true,
            "call_id": {
              "type": "string"
            },
            "tool_name": {
              "type": "string"
            },
            "type": {
              "const": "tool_call",
              "type": "string"
            }
          },
          "required": [
            "type",
            "tool_name",
            "arguments",
            "call_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "call_id": {
              "type": "string"
            },
            "result": {
              "type": "string"
            },
            "type": {
              "const": "tool_result",
              "type": "string"
            }
          },
          "required": [
            "type",
            "call_id",
            "result"
          ],
          "type": "object"
        },
        {
          "properties": {
            "context_usage": {
              "format": "float",
              "type": "number"
            },
            "transcript": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "type": {
              "const": "compaction_pending",
              "type": "string"
            }
          },
          "required": [
            "type",
            "transcript",
            "context_usage"
          ],
          "type": "object"
        },
        {
          "properties": {
            "session_id": {
              "type": "string"
            },
            "type": {
              "const": "complete",
              "type": "string"
            }
          },
          "required": [
            "type",
            "session_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "session_id": {
              "type": "string"
            },
            "type": {
              "const": "interrupted",
              "type": "string"
            }
          },
          "required": [
            "type",
            "session_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "message": {
              "type": "string"
            },
            "type": {
              "const": "error",
              "type": "string"
            }
          },
          "required": [
            "type",
            "message"
          ],
          "type": "object"
        }
      ]
    },
